{
  "name": "database",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "build": "echo no-op",
    "check": "prisma generate && tsc --noEmit",
    "postinstall": "prisma generate",
    "generate": "prisma generate",
    "push": "prisma db push",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:mark-init-applied": "prisma migrate resolve --applied 20250101000000_init",
    "migrate:recover-failed-init": "prisma migrate resolve --rolled-back 20250101000000_init",
    "studio": "prisma studio",
    "seed": "prisma db seed",
    "seed:test-profile": "node scripts/seed-test-profile-member.js",
    "delete:test-profile": "node scripts/delete-test-profile-member.js",
    "verify:leaderboard": "node scripts/verify-leaderboard.js",
    "import-businesses": "node scripts/import-businesses-admin.js scripts/import-businesses.json"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
