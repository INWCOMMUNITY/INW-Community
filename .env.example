# Database (required for main + admin)
DATABASE_URL="postgresql://user:password@localhost:5432/northwest_community"
# Neon on Vercel: optional unpooled URL for migrations (or omit — migrate-deploy derives direct URL from pooled DATABASE_URL).
# DATABASE_URL_UNPOOLED="postgresql://..."
# DIRECT_URL="postgresql://..."
# On Vercel + Neon, migrate-deploy sets PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK for migrate only. Set to 0 to keep Prisma’s lock (run one deploy at a time).
# PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=0

# Main app – Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
# Optional: comma-separated extra base URLs allowed for Stripe success/cancel redirects (e.g. http://192.168.1.140:3000 for device testing). Must match request origin; unknown origins fall back to NEXTAUTH_URL.
# CHECKOUT_ALLOWED_BASE_URLS=

# Main app – Stripe (subscriptions + storefront payments)
# Keys: https://dashboard.stripe.com/apikeys — sk_test_/pk_test_ for sandbox, sk_live_/pk_live_ for production.
# Local dev matching the live site: use live keys + live price IDs here (same as Vercel).
STRIPE_SECRET_KEY="sk_test_..."   # Required for storefront checkout, Connect, webhooks
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..." # Required for custom checkout page (Payment Element)
STRIPE_WEBHOOK_SECRET="whsec_..." # From Stripe CLI or dashboard webhooks
STRIPE_PRICE_SUBSCRIBE="price_..."   # $10/mo
STRIPE_PRICE_SPONSOR="price_..."    # $20/mo
STRIPE_PRICE_SELLER="price_..."    # $30/mo

# Admin – session-based login (/admin requires authorized member; admin uses /login with these credentials)
# Can live in root .env – main app loads it via next.config.js
ADMIN_EMAIL="NWCADMIN57611"
# Only for initial setup; remove after first seed: pnpm db:seed
# Value is used literally – do not use angle brackets as placeholders (e.g. use MyPass123! not <MyPass123!>)
ADMIN_INITIAL_PASSWORD=""

# Admin – code for x-admin-code header (scripts, cron, non-browser callers)
ADMIN_CODE="NWC36481"
NEXT_PUBLIC_ADMIN_CODE="NWC36481"

# Admin app – main site URL (for Editor Mode iframe)
NEXT_PUBLIC_MAIN_SITE_URL="http://localhost:3000"
# Live site URL (for "edit live" banner when running admin locally)
NEXT_PUBLIC_LIVE_SITE_URL="https://yoursite.com"

# Main app – EasyPost (shipping labels, rates)
# Get key from https://www.easypost.com/account/api-keys (use test key for dev)
EASYPOST_API_KEY="EZAK..."
# Partner/Forge key for creating seller Referral Customer accounts (sellers pay for labels with their card)
# If unset, EASYPOST_API_KEY is used for connect; Referral Customers require Partner access in production.
EASYPOST_PARTNER_API_KEY=""
# Main app – required for Set Up Easy Post (encrypts seller EasyPost API keys at rest)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# Main app – Shippo OAuth (“Connect with Shippo” for sellers)
# https://docs.goshippo.com/docs/oauth_integrations/oauth — register callback(s) with Shippo first, e.g.:
#   https://yourdomain.com/api/shipping/oauth-callback
#   http://localhost:3000/api/shipping/oauth-callback  (only if Shippo allowlisted it)
SHIPPO_OAUTH_CLIENT_ID=""
SHIPPO_OAUTH_CLIENT_SECRET=""
# Shippo may assign this for OAuth step 1; code defaults to northwestcommunity if unset
SHIPPO_OAUTH_UTM_SOURCE="northwestcommunity"
# Server-side Shippo (e.g. /api/validate-address at checkout). From Shippo → Settings → API.
# Use shippo_live_... locally if you want the same behavior as production (Vercel). Not sent to the browser.
SHIPPO_API_KEY=""

# Cloudinary – cloud name from dashboard (e.g. djmi9rod0). Required for thanks image, directory background, etc.
# Admin-replaced site images are routed through Cloudinary with AI upscale; add your domain and *.blob.vercel-storage.com to Allowed fetch sites in Cloudinary if needed.
CLOUDINARY_CLOUD_NAME=""

# Cloudinary – high-res thanks photo. Upload thanks-landscape.png to Media Library, set public_id (e.g. thanks-landscape)
NEXT_PUBLIC_CLOUDINARY_THANKS_IMAGE=""

# Cloudinary – business directory header background. Public ID from Media Library (e.g. background_lv6evz)
NEXT_PUBLIC_CLOUDINARY_DIRECTORY_BACKGROUND="background_lv6evz"

# --- Local dev = same APIs as live (optional) ---
# The app does not force “test” mode when NODE_ENV=development — Stripe/Shippo use whatever keys you set.
# To match www production while running pnpm dev: put sk_live_/pk_live_, live price IDs, shippo_live_ SHIPPO_API_KEY,
# and (if needed) production DATABASE_URL in root .env. Keep NEXTAUTH_URL=http://localhost:3000 so cookies and
# OAuth work in the browser on localhost; add localhost URLs in Stripe Dashboard if you use live keys locally.

# --- Production / Go live ---
# Main: Use live Stripe keys (sk_live_..., pk_live_...) and live price IDs. Set NEXTAUTH_URL to prod URL.
# Main: BLOB_READ_WRITE_TOKEN for site image uploads (Vercel Blob).
# Admin: Set NEXT_PUBLIC_MAIN_SITE_URL to your main site URL (e.g. https://northwestcommunity.com).
# Admin: Set ADMIN_CODE and NEXT_PUBLIC_ADMIN_CODE to a strong secret (change from default).
# Both: Use production DATABASE_URL. Run db:seed once if needed.