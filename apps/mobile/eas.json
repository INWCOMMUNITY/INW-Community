{
  "cli": {
    "version": ">= 18.0.1",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.inwcommunity.com",
        "EXPO_PUBLIC_REALTIME_URL": "https://inw-community-production.up.railway.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.inwcommunity.com",
        "EXPO_PUBLIC_REALTIME_URL": "https://inw-community-production.up.railway.app"
      }
    },
    "production": {
      "autoIncrement": false,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.inwcommunity.com",
        "EXPO_PUBLIC_REALTIME_URL": "https://inw-community-production.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
