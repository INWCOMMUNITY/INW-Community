{
  "expo": {
    "name": "INW Community",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "inwcommunity",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#f8e7c9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.northwestcommunity.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "inwcommunity.com": {
              "NSExceptionRequiresForwardSecrecy": false,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.jpg",
        "backgroundColor": "#f8e7c9"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.northwestcommunity.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f8e7c9"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": true,
          "includeOnramp": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow INW Community to use the camera to scan QR codes at local businesses."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow INW Community to access your photos so you can share images in posts, messages, and your profile."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d6f27282-4d48-4851-981f-bd2fba7cb69c"
      }
    },
    "owner": "northwestcommunity"
  }
}
