{
  "expo": {
    "name": "INW Community",
    "slug": "mobile",
    "version": "2.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "inwcommunity",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8e7c9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.northwestcommunity.app",
      "buildNumber": "1",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["maps", "http", "https", "geo"],
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "inwcommunity.com": {
              "NSExceptionRequiresForwardSecrecy": false,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f8e7c9"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.northwestcommunity.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#8B4513",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "colorAccent": { "light": "#505542", "dark": "#505542" },
              "colorControlActivated": { "light": "#505542", "dark": "#505542" }
            },
            "timePicker": {
              "headerBackground": { "light": "#505542", "dark": "#505542" },
              "numbersSelectorColor": { "light": "#505542", "dark": "#505542" }
            }
          }
        }
      ],
      "./plugins/withAndroidAppPrimaryColor.js",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f8e7c9"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": true,
          "includeOnramp": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow INW Community to use the camera to scan QR codes at local businesses."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow INW Community to access your photos so you can share images in posts, messages, and your profile."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d6f27282-4d48-4851-981f-bd2fba7cb69c"
      }
    },
    "owner": "northwestcommunity"
  }
}
