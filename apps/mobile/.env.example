# Copy to .env and adjust. .env is gitignored.

# --- Local dev (Expo Go + local Next.js on port 3000) ---
# From repo root: pnpm dev:main  (Next listens on 0.0.0.0:3000)
# Physical phone: EXPO_PUBLIC_API_URL=http://YOUR_PC_LAN_IP:3000  (phone and PC on same Wi‑Fi)
#   "localhost" on the phone is the phone itself, not your computer.
# iOS Simulator: http://127.0.0.1:3000
# Android emulator: http://10.0.2.2:3000
# Windows: Get-NetIPAddress -AddressFamily IPv4  to list IPs

# --- Production ---
# EXPO_PUBLIC_API_URL=https://www.inwcommunity.com
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000

# Live chat Socket.IO — MUST match NEXT_PUBLIC_REALTIME_URL on the main site (same host) so website and app share one server.
# Physical phone + EXPO_PUBLIC_API_URL=http://YOUR_PC_LAN:3000:
#   Either omit EXPO_PUBLIC_REALTIME_URL (defaults to same host as API, port 3007), OR set EXPO_PUBLIC_REALTIME_URL
#   to http://YOUR_PC_LAN:3007. Do NOT use 127.0.0.1 on the phone unless you only use iOS Simulator.
#   (If you mistakenly set 127.0.0.1:3007, the app rewrites to the API host in dev when API uses a LAN IP.)
# Production: EXPO_PUBLIC_REALTIME_URL=wss://your-realtime-host (same as NEXT_PUBLIC_REALTIME_URL on Vercel).
# EXPO_PUBLIC_REALTIME_URL=http://YOUR_LAN_IP:3007
# EXPO_PUBLIC_REALTIME_PORT=3007

# Stripe: same publishable key as main site (pk_test_... / pk_live_...)
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
