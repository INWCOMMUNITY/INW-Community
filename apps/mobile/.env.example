# Copy to .env and adjust. .env is gitignored.

# --- Local dev (Expo Go + local Next.js on port 3000) ---
# From repo root: pnpm dev:main  (Next listens on 0.0.0.0:3000)
# Physical phone: EXPO_PUBLIC_API_URL=http://YOUR_PC_LAN_IP:3000  (phone and PC on same Wi‑Fi)
#   "localhost" on the phone is the phone itself, not your computer.
# iOS Simulator: http://127.0.0.1:3000
# Android emulator: http://10.0.2.2:3000
# Windows: Get-NetIPAddress -AddressFamily IPv4  to list IPs

# --- Production ---
# EXPO_PUBLIC_API_URL=https://www.inwcommunity.com
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000

# Stripe: same publishable key as main site (pk_test_... / pk_live_...)
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
